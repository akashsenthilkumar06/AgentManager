# Copy this file to .env. The backend loads it automatically on startup.
# Keep .env private; it is intentionally ignored by Git.
#
# Required for OpenAI-backed Manager routing and live HTTP(S) MCP conversations.
# Create a project API key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=your_api_key_here

# Balanced current GPT-5.6 tier for this tool-using control-plane workload.
# Use gpt-5.6-sol for maximum capability or gpt-5.6-luna for lower-cost routing.
OPENAI_MODEL=gpt-5.6-terra
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional when the API key already belongs to the intended project.
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=

# Responses API controls. "low" keeps interactive tool loops responsive.
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=1600
OPENAI_REQUEST_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2

# Stable, privacy-preserving identifier for this local app user.
OPENAI_SAFETY_IDENTIFIER=agent-manager-local

# Override this only to load a different env file. Empty disables dotenv loading.
AGENT_MANAGER_ENV_FILE=.env

AGENT_MANAGER_DATA_DIR=backend/data
AGENT_MANAGER_GENERATED_DIR=backend/generated_tools
AGENT_MANAGER_FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AGENT_MANAGER_BACKEND_PORT=8000
AGENT_MANAGER_FRONTEND_PORT=5173
# Zero-token fleet discovery/health sweep interval (minimum 5 seconds).
AGENT_MANAGER_RECONCILIATION_INTERVAL_SECONDS=30
# Read-only default root visible to the Manager Agent.
AGENT_MANAGER_WORKSPACE_ROOT=.
