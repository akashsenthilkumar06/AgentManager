# Optional for the local demo; required for live HTTP(S) MCP conversations.
# Without it, client-agent responses are explicitly labeled deterministic fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_MANAGER_DATA_DIR=backend/data
AGENT_MANAGER_GENERATED_DIR=backend/generated_tools
AGENT_MANAGER_FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AGENT_MANAGER_BACKEND_PORT=8000
AGENT_MANAGER_FRONTEND_PORT=5173
# Read-only root visible to the Manager Agent and Files page.
AGENT_MANAGER_WORKSPACE_ROOT=.
